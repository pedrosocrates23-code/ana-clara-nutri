---
// O CSS pronto do Fontsource declarava 16 @font-face cobrindo 13 subsets
// (cirílico, grego, vietnamita...). Como o CSS é inline, esses ~10 KiB de
// declarações inúteis iam em TODA página, e os .woff2 dos subsets eram
// publicados em dist/. O site é pt-BR: só o latino importa.
// Declaramos as fontes à mão em fonts.css, importando os arquivos abaixo.
import '../styles/fonts.css';
// woff2 das fontes críticas above-the-fold (preload p/ CWV)
import hankenWoff2 from '@fontsource-variable/hanken-grotesk/files/hanken-grotesk-latin-wght-normal.woff2?url';
import newsreaderWoff2 from '@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url';
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFloat from '../components/WhatsappFloat.astro';
import Analytics from '../components/Analytics.astro';
import { SITE, absoluteUrl } from '../lib/site';

interface Props {
  title: string;
  description: string;
  path?: string;
  graph?: object;          // @graph JSON-LD da página (buildGraph)
  overHero?: boolean;      // header transparente sobre hero full-bleed
  ogImage?: string;
}
const { title, description, path = Astro.url.pathname, graph, overHero = false, ogImage } = Astro.props;
const canonical = absoluteUrl(path);
const fullTitle = title.includes(SITE.name) ? title : `${title}`;
const img = ogImage ?? '/og-default.jpg';
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preload" href={hankenWoff2} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={newsreaderWoff2} as="font" type="font/woff2" crossorigin />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(img, SITE.url).href} />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" type="image/png" href="/favicon.png" />

  {graph && (
    <script type="application/ld+json" set:html={JSON.stringify(graph)} />
  )}

  <!-- Google tag (gtag.js) + Microsoft Clarity -->
  <Analytics />
</head>
<body>
  <!-- Sentinela do header: ver o script abaixo. Não ocupa espaço nem é lido por leitores de tela. -->
  <div data-topo aria-hidden="true"></div>
  <Header overHero={overHero} />
  <main id="conteudo">
    <slot />
  </main>
  <Footer />
  <WhatsappFloat />

  <!-- Header sólido ao rolar + reveal on scroll (ilhas mínimas) -->
  <script>
    // O header fica sólido quando a sentinela do topo sai da viewport.
    //
    // A versão anterior usava um listener de scroll lendo window.scrollY. Ler
    // geometria durante o scroll obriga o navegador a recalcular o layout
    // (forced reflow, ~37ms no Lighthouse). O IntersectionObserver entrega a
    // mesma informação de forma assíncrona, sem tocar no layout.
    const header = document.querySelector('[data-header]');
    const topo = document.querySelector('[data-topo]');

    if (header && topo) {
      new IntersectionObserver(
        ([entry]) => header.classList.toggle('is-solid', !entry.isIntersecting),
        { threshold: 0 },
      ).observe(topo);
    }

    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    } else {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
    }
  </script>
</body>
</html>
