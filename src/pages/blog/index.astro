---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { buildGraph } from '../../lib/schema/shared';
import { formatarDataPt } from '../../lib/site';

const posts = (await getCollection('posts')).sort(
 (a, b) => (a.data.datePublished < b.data.datePublished ? 1 : -1)
);
const breadcrumb = [{ name: 'Início', href: '/' }, { name: 'Blog', href: '/blog' }];
const graph = buildGraph({ path: '/blog', title: 'Blog | Ana Clara Nutri', breadcrumb });
---
<BaseLayout
 title="Blog | Ana Clara Nutri"
 description="Conteúdo sobre alimentação, comportamento e saúde, em linguagem simples e baseada em evidências."
 path="/blog" graph={graph}>
 <PageHero kicker="Conteúdo" title="Blog" sub="Textos sobre alimentação, comportamento e saúde, em linguagem simples e baseada em evidências." breadcrumb={breadcrumb} />

 <section class="section">
 <div class="container">
 {posts.length === 0 ? (
 <p class="muted">Em breve, novos conteúdos por aqui.</p>
 ) : (
 <div class="grid grid--2">
 {posts.map((p) => (
 <a class="card post" href={p.data.path}>
 <div class="post__media">
 {p.data.image && (
 <img class="post__thumb" src={p.data.image} alt={p.data.imageAlt ?? p.data.title} width="1536" height="1024" loading="lazy" />
 )}
 <span class="post__badge">{p.data.siloLabel}</span>
 </div>
 <div class="post__body">
 {/* h2, não h3: o h1 da página é "Blog" e cada card é uma seção direta dele.
     Pular de h1 para h3 quebra a ordem de cabeçalhos para leitores de tela. */}
 <h2>{p.data.title}</h2>
 <p>{p.data.description}</p>
 <div class="post__foot">
 <span class="post__date">{formatarDataPt(p.data.datePublished)}</span>
 <span class="post__more">Ler mais →</span>
 </div>
 </div>
 </a>
 ))}
 </div>
 )}
 </div>
 </section>
</BaseLayout>

<style>
 /* Card sem padding uniforme: a imagem precisa encostar nas bordas/cantos do
    card (sem "moldura"), então o padding só entra no corpo de texto. */
 .card.post { display: flex; flex-direction: column; padding: 0; overflow: hidden; text-decoration: none; color: inherit; }
 .post:hover { text-decoration: none; }

 .post__media { position: relative; }
 .post__thumb { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; display: block; }
 .post__badge {
 position: absolute; top: 14px; left: 14px; max-width: calc(100% - 28px);
 background: var(--sage-700); color: #fff;
 font-family: var(--sans); font-size: .74rem; font-weight: 600; line-height: 1.3;
 padding: 5px 14px; border-radius: 999px;
 }

 .post__body { display: flex; flex-direction: column; gap: 6px; padding: 20px 22px 22px; }
 /* h2 semântico, mas com o tamanho visual de h3: a hierarquia é para o leitor
    de tela, não para a escala tipográfica do card. */
 .post__body h2 { margin: 0; font-size: clamp(1.1rem, 2vw, 1.3rem); }
 .post__body p { color: var(--ink-soft); font-size: .92rem; margin: 0; }
 .post__foot { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 10px; }
 .post__date { color: var(--ink-faint); font-size: .82rem; }
 .post__more { color: var(--sage-700); font-weight: 600; font-size: .9rem; white-space: nowrap; }
 .muted { color: var(--ink-faint); }
</style>
