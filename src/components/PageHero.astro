---
import Button from './Button.astro';
interface Props {
  kicker?: string;
  title: string;
  sub?: string;
  cta?: { label: string; href: string };
  breadcrumb?: { name: string; href: string }[];
}
const { kicker, title, sub, cta, breadcrumb } = Astro.props;
---
<section class="page-hero">
  <div class="container">
    {breadcrumb && (
      <nav class="crumbs" aria-label="Você está em">
        {breadcrumb.map((b, i) => (
          <>{i > 0 && <span class="sep">›</span>}<a href={b.href}>{b.name}</a></>
        ))}
      </nav>
    )}
    <div class="reveal">
      {kicker && <span class="kicker">{kicker}</span>}
      <h1 set:html={title} />
      {sub && <p class="page-hero__sub">{sub}</p>}
      {cta && <Button href={cta.href} variant="clay">{cta.label}</Button>}
    </div>
  </div>
</section>

<style>
  .page-hero { background: linear-gradient(180deg, var(--paper) 0%, var(--sage-50) 100%);
    padding-block: clamp(36px, 7vw, 72px); border-bottom: 1px solid var(--line); }
  .crumbs { font-family: var(--mono); font-size: .72rem; color: var(--ink-faint); margin-bottom: 14px; }
  .crumbs a { color: var(--ink-faint); text-decoration: none; }
  .crumbs a:hover { color: var(--sage-700); }
  .crumbs .sep { margin: 0 6px; }
  .page-hero h1 { max-width: 720px; }
  .page-hero h1 :global(em) { font-style: italic; color: var(--sage-600); }
  .page-hero__sub { font-size: clamp(1rem, 1.6vw, 1.15rem); color: var(--ink-soft); max-width: 560px; margin: 14px 0 24px; }
</style>
