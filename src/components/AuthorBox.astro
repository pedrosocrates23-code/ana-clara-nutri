---
import { SITE } from '../lib/site';
---
<aside class="author">
  <img src="/logo-aca.png" alt="" width="48" height="48" class="author__img" />
  <div>
    <p class="author__name">{SITE.legalName}</p>
    <p class="author__meta">Nutricionista · {SITE.crn} · abordagem comportamental e educacional</p>
    <a class="author__link" href="/sobre">Conheça meu trabalho →</a>
  </div>
</aside>

<style>
  .author { display: flex; gap: 14px; align-items: center; background: var(--paper-2);
    border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px 20px; margin-top: 36px; }
  .author__img { border-radius: 50%; background: #fff; flex: 0 0 48px; }
  .author__name { font-family: var(--serif); font-size: 1.1rem; margin: 0; }
  .author__meta { font-size: .85rem; color: var(--ink-soft); margin: 2px 0 6px; }
  .author__link { font-size: .85rem; font-weight: 600; color: var(--sage-700); }
</style>
