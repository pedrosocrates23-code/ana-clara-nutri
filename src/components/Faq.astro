---
// FAQ visível (UX + captura PAA/AI Overview). O markup FAQPage vem do @graph (não rich result).
interface Props { items: { q: string; a: string }[]; title?: string }
const { items, title = 'Perguntas frequentes' } = Astro.props;
---
<section class="section faq" aria-label={title}>
 <div class="container">
 <div class="section__head"><span class="kicker">FAQ</span><h2>{title}</h2></div>
 <div class="faq__list">
 {items.map((item) => (
 <details class="faq__item">
 <summary>{item.q}</summary>
 <p>{item.a}</p>
 </details>
 ))}
 </div>
 </div>
</section>

<style>
 .faq__list { max-width: var(--maxw-prose); }
 .faq__item { border-bottom: 1px solid var(--line); padding: 6px 0; }
 .faq__item summary {
 cursor: pointer; list-style: none; padding: 14px 0; font-weight: 600;
 display: flex; justify-content: space-between; align-items: center; gap: 16px;
 }
 .faq__item summary::after { content: '+'; font-family: var(--mono); color: var(--sage-600); font-size: 1.2rem; }
 .faq__item[open] summary::after { content: ', '; }
 .faq__item p { color: var(--ink-soft); padding: 0 0 14px; margin: 0; }
</style>
