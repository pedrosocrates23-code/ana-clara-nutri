---
import { SITE, ADDRESS_LINE, MAPS_EMBED_URL, MAPS_LINK } from '../lib/site';
interface Props { title?: string }
const { title = 'Mapa do local de atendimento em Goiânia' } = Astro.props;
---
<div class="map">
  <iframe
    src={MAPS_EMBED_URL}
    title={title}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen></iframe>
</div>
<address class="map__address">
  <strong>{SITE.venue}</strong><br />
  {ADDRESS_LINE}<br />
  <span class="map__note">Atendimento de {SITE.legalName}, nutricionista.</span><br />
  <a href={MAPS_LINK} target="_blank" rel="noopener">Abrir no Google Maps →</a>
</address>

<style>
  .map {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 16 / 10;
  }
  @media (min-width: 720px) { .map { aspect-ratio: 16 / 8; } }
  .map iframe { display: block; width: 100%; height: 100%; border: 0; }
  .map__address {
    font-style: normal;
    margin-top: 14px;
    color: var(--ink-soft);
    font-size: .92rem;
    line-height: 1.7;
  }
  .map__address a { color: var(--sage-700); font-weight: 600; }
  .map__note { color: var(--ink-faint); font-size: .86rem; }
</style>
