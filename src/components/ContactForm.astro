---
// Seção de agendamento do rodapé (faixa verde + intro + FormCard).
import FormCard from './FormCard.astro';
---
<section class="agendar" id="agendar" aria-label="Agendar consulta">
  <div class="container agendar__grid">
    <div class="agendar__intro reveal">
      <span class="kicker kicker--light">Agendamento</span>
      <h2>Vamos começar?</h2>
      <p>Preencha o formulário e eu retorno para confirmar o seu horário. Atendimento particular, online para todo o Brasil ou presencial em Goiânia.</p>
      <ul class="agendar__points">
        <li>Resposta individual, sem robô</li>
        <li>Atendimento online e presencial</li>
        <li>Seus dados protegidos (LGPD)</li>
      </ul>
    </div>
    <div class="reveal"><FormCard idPrefix="rodape" /></div>
  </div>
</section>

<style>
  .agendar {
    background: linear-gradient(160deg, var(--sage-700) 0%, var(--sage-800) 100%);
    color: #fff; padding-block: clamp(48px, 8vw, 88px);
  }
  .agendar__grid { display: grid; gap: 32px; }
  @media (min-width: 860px) { .agendar__grid { grid-template-columns: .85fr 1.15fr; align-items: center; } }
  .agendar__intro h2 { color: #fff; margin: 10px 0 0; }
  .kicker--light { color: var(--sage-200); }
  .agendar__intro p { color: rgba(255, 255, 255, .9); margin: 14px 0 18px; max-width: 380px; }
  .agendar__points { list-style: none; padding: 0; margin: 0; display: grid; gap: 9px; }
  .agendar__points li { color: var(--sage-100); font-size: .92rem; padding-left: 24px; position: relative; }
  .agendar__points li::before { content: '✓'; position: absolute; left: 0; color: var(--sage-300); font-family: var(--mono); }
</style>
