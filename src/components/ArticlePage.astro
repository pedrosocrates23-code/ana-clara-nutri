---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import Faq from './Faq.astro';
import AuthorBox from './AuthorBox.astro';
import References from './References.astro';
import Button from './Button.astro';
import TableOfContents from './TableOfContents.astro';
import { buildGraph, SCHEMA_IDS } from '../lib/schema/shared';
import { SITE, WHATSAPP_URL } from '../lib/site';

const { entry } = Astro.props;
const { data } = entry;
const { Content, headings } = await render(entry);

const siloHref = data.silo === 'blog' ? '/blog' : `/${data.silo}/`;
const breadcrumb = [
  { name: 'Início', href: '/' },
  { name: data.siloLabel, href: siloHref },
  { name: data.title, href: data.path },
];

const articleNode = {
  '@type': data.medical ? 'MedicalWebPage' : 'Article',
  '@id': `${SITE.url}${data.path}#article`,
  headline: data.title,
  description: data.description,
  author: { '@id': SCHEMA_IDS.person },
  publisher: { '@id': SCHEMA_IDS.person },
  datePublished: data.datePublished,
  dateModified: data.datePublished,
  inLanguage: 'pt-BR',
  ...(data.medical ? { lastReviewed: data.datePublished, reviewedBy: { '@id': SCHEMA_IDS.person } } : {}),
};

const graph = buildGraph({
  path: data.path, title: data.metaTitle, faqs: data.faqs, breadcrumb,
  extraNodes: [articleNode],
});
---
<BaseLayout title={data.metaTitle} description={data.description} path={data.path} graph={graph}>
  <PageHero kicker={data.siloLabel} title={data.h1} breadcrumb={breadcrumb} />

  {data.image && (
    <figure class="article-cover">
      <img src={data.image} alt={data.imageAlt ?? data.h1} width="1536" height="1024" loading="eager" fetchpriority="high" />
    </figure>
  )}

  <article class="section">
    <div class="container article-layout">
      <div class="article-layout__content prose">
        <Content />
        <AuthorBox />
        <p class="back"><a href={siloHref}>← Voltar para {data.siloLabel}</a></p>
      </div>
      <aside class="article-layout__toc">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </article>

  {data.faqs.length > 0 && <Faq items={data.faqs} />}

  {data.references?.length > 0 && <References items={data.references} />}

  <section class="section cta-final">
    <div class="container reveal">
      <h2>Quer um acompanhamento individual?</h2>
      <p>Atendimento online para todo o Brasil ou presencial em Goiânia, sem dieta restritiva e sem culpa.</p>
      <div class="cta-final__actions">
        <Button href={WHATSAPP_URL} variant="clay" target="_blank" rel="noopener">Falar no WhatsApp</Button>
        <Button href="/sobre" variant="outline">Conhecer o atendimento</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .article-cover {
    max-width: var(--maxw, 1120px);
    margin: 0 auto 8px;
    padding-inline: var(--gutter, 20px);
  }
  .article-cover img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 14px;
    display: block;
  }
  .back { margin-top: 24px; font-weight: 600; }
  .cta-final { text-align: center; background: var(--paper-2); }
  .cta-final p { margin-inline: auto; }
  .cta-final__actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 18px; }

  /* Mobile: conteúdo empilhado, sem sumário (posição atual, sem alterações). */
  .article-layout__toc { display: none; }

  /* Desktop: conteúdo à esquerda, sumário fixo à direita. */
  @media (min-width: 960px) {
    .article-layout {
      display: grid;
      grid-template-columns: minmax(0, var(--maxw-prose)) minmax(240px, 300px);
      gap: 56px;
      align-items: start;
    }
    .article-layout__content { max-width: var(--maxw-prose); }
    .article-layout__toc {
      display: block;
      position: sticky;
      top: calc(var(--header-h) + 24px);
    }
  }
</style>
